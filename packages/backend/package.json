{
  "name": "@app/backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate:sqlite",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/static": "^8",
    "better-sqlite3": "^9",
    "drizzle-orm": "^0.30",
    "fastify": "^5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7",
    "drizzle-kit": "^0.20",
    "tsx": "^4",
    "vitest": "^2"
  }
}
